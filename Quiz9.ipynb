      "source": [
        "##Compute the average time for a trip based on starting point"
      ],
      "metadata": {
        "id": "k7baKUbhMXXR"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "%%bigquery --project dataviz-488505\n",
        "SELECT AVG(duration_minutes) AS avg_time, start_station_name\n",
        "FROM `bigquery-public-data.austin_bikeshare.bikeshare_trips`\n",
        "WHERE start_station_name = '10th/Red River'\n",
        "GROUP BY start_station_name"
